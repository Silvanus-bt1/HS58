# === REQUIRED ===
PROVIDER_PRIVATE_KEY=0xYOUR_POLYGON_PRIVATE_KEY

# === AGCLI / BITTENSOR ===
AGCLI_PATH=agcli
SUBTENSOR_ENDPOINT=wss://entrypoint-finney.opentensor.ai:443

# === DRAIN / BLOCKCHAIN ===
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json

# === SERVER ===
PORT=3000
HOST=0.0.0.0
PROVIDER_NAME=Community-agcli

# === RATE LIMITING ===
READ_RATE_LIMIT_PER_MINUTE=20
WRITE_RATE_LIMIT_PER_MINUTE=5

# === OPTIONAL ===
ADMIN_PASSWORD=
AGCLI_TIMEOUT_READ=30
AGCLI_TIMEOUT_WRITE=120
