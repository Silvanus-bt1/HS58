# === DRAIN Payment Config (required) ===
PROVIDER_PRIVATE_KEY=0x...

# Recommended: Reliable Polygon RPC (free at alchemy.com or infura.io)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# === Hippius S3 Credentials (required) ===
# Generate at https://console.hippius.com
HIPPIUS_ACCESS_KEY=your-hippius-access-key
HIPPIUS_SECRET_KEY=your-hippius-secret-key

# === Hippius Config (optional, defaults shown) ===
HIPPIUS_ENDPOINT=https://s3.hippius.com
HIPPIUS_REGION=us-east-1
HIPPIUS_IPFS_BUCKET=ipfs-pins

# === Pricing in USD (optional, defaults shown) ===
PRICE_PER_MB_UPLOAD=0.005
PRICE_PER_MB_DOWNLOAD=0.001
PRICE_PER_LIST=0.001
PRICE_PER_CREATE_BUCKET=0.01
PRICE_PER_DELETE=0.001
PRICE_PER_MB_IPFS_PIN=0.005
MARKUP_PERCENT=50

# === Limits (optional, defaults shown) ===
MAX_FILE_SIZE_MB=100
RATE_LIMIT_PER_MINUTE=30

# === Admin (optional) ===
ADMIN_PASSWORD=

# === Optional (defaults shown) ===
PORT=3000
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
PROVIDER_NAME=Community-Hippius
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json
