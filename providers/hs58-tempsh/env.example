# === DRAIN Payment Config (required) ===
PROVIDER_PRIVATE_KEY=0x...

# Recommended: Reliable Polygon RPC (free at alchemy.com or infura.io)
# Without this, the public RPC is used (rate-limited, claims may fail)
POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_API_KEY

# === Pricing (optional, defaults shown) ===
# Pricing mode: "flat" (per upload) or "per-mb" (per megabyte)
PRICING_MODE=flat

# Price per upload in USD (used when PRICING_MODE=flat, default: $0.005)
PRICE_PER_UPLOAD=0.005

# Price per MB in USD (used when PRICING_MODE=per-mb, default: $0.002)
PRICE_PER_MB=0.002

# Markup multiplier as percent (e.g. 50 = 1.5x = 50% profit margin)
MARKUP_PERCENT=50

# === Limits (optional, defaults shown) ===
# Maximum file size in MB (temp.sh supports up to 4000 MB)
MAX_FILE_SIZE_MB=100

# Max uploads per minute per payment channel
RATE_LIMIT_PER_MINUTE=20

# Restrict to specific MIME types (comma-separated, empty = allow all)
# ALLOWED_MIME_TYPES=image/png,image/jpeg,application/pdf,text/plain

# === Admin (optional) ===
# Password for /v1/admin/* endpoints (empty = no auth)
ADMIN_PASSWORD=

# === Optional (defaults shown) ===
PORT=3000
CHAIN_ID=137
CLAIM_THRESHOLD=1000000
PROVIDER_NAME=HS58-TempSh
AUTO_CLAIM_INTERVAL_MINUTES=10
AUTO_CLAIM_BUFFER_SECONDS=3600
STORAGE_PATH=./data/vouchers.json
