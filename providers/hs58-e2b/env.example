# ============================================================
# HS58-E2B Provider — Environment Variables
# ============================================================

# --- REQUIRED ---

# Your E2B API key (get it at https://e2b.dev/dashboard?tab=keys)
E2B_API_KEY=e2b_***

# Provider private key (Ethereum/Polygon wallet for DRAIN payments)
PROVIDER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# --- OPTIONAL ---

# Blockchain: 137 = Polygon Mainnet, 80002 = Amoy Testnet (default: 137)
CHAIN_ID=137

# Custom Polygon RPC URL (default: public viem RPC — rate-limited)
# POLYGON_RPC_URL=https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY

# Provider display name in the marketplace (default: HS58-E2B)
PROVIDER_NAME=HS58-E2B

# Markup percentage on top of base prices (default: 50, meaning +50%)
MARKUP_PERCENT=50

# Max execution time per sandbox in milliseconds (default: 120000 = 2 min)
# E2B charges per second — longer timeout = higher potential cost
SANDBOX_TIMEOUT_MS=120000

# Minimum USDC to accumulate before auto-claiming (default: 1000000 = $1.00)
CLAIM_THRESHOLD=1000000

# Server port (default: 3000)
PORT=3000

# Server host (default: 0.0.0.0)
HOST=0.0.0.0

# Storage path for vouchers (default: ./data/vouchers.json)
STORAGE_PATH=./data/vouchers.json

# Auto-claim: check interval in minutes (default: 10)
AUTO_CLAIM_INTERVAL_MINUTES=10

# Auto-claim: claim channels expiring within this many seconds (default: 3600 = 1 hour)
AUTO_CLAIM_BUFFER_SECONDS=3600
